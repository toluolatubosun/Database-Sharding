DEPLOYMENT_ENV=development

# --- Resharding migration (opt-in) ---
# Uncomment + restart the backend to enable dual-write to a new shard.
# See PLAN.md for the full flow. Leave commented for the default 3-shard demo.
#
# MIGRATION_PHASE=dual_write          # idle | allow_migrations | dual_write | cutover
# MIGRATION_TARGET_SHARD=shard_3
# MIGRATION_TARGET_URL=postgresql://postgres:password@shard_3:5432/shard_3
